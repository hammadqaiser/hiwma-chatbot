# Waste Management RAG Chatbot — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required: set the API key for your chosen provider (see config.yaml → llm.provider)
# Only ONE provider key is needed at a time.

# Groq (default provider — free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local — no key needed, just the base URL)
OLLAMA_BASE_URL=http://localhost:11434
